{
  "name": "@e-commerce/client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rsbuild build",
    "check": "pnpm run \"/^check:(lint|types|test)$/\"",
    "check:lint": "biome check --write",
    "check:test": "rstest",
    "check:types": "tsc --noEmit",
    "dev": "node --experimental-vm-modules ssr/dev.mjs",
    "format": "biome format --write",
    "preview": "node ssr/prod.mjs",
    "test": "rstest",
    "test:watch": "rstest --watch"
  },
  "dependencies": {
    "@e-commerce/contracts": "workspace:*",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-virtual": "^3.14.5",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@rsbuild/core": "^2.1.4",
    "@rsbuild/plugin-react": "^2.1.0",
    "@rsbuild/plugin-tailwindcss": "^2.0.3",
    "@rstest/adapter-rsbuild": "^0.10.6",
    "@rstest/core": "^0.10.6",
    "@storybook/react": "^10.5.2",
    "@tanstack/router-plugin": "^1.168.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.10.6",
    "storybook": "^10.5.2",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  }
}
