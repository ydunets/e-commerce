LOG_LEVEL=info
NODE_ENV=development
PORT=3000
POSTGRES_PASSWORD=test
POSTGRES_USER=admin
POSTGRES_DB=test
POSTGRES_URL=127.0.0.1:5432
# TLS mode for the DB connection: "disable" locally, "require" for managed Postgres (e.g. Azure).
POSTGRES_SSLMODE=disable
DBMATE_DATABASE_URL=postgres://admin:test@127.0.0.1:5432/test?sslmode=disable

# OpenTelemetry — disabled by default; enable when a collector is available.
# See https://opentelemetry.io/docs/languages/sdk-configuration/general/
OTEL_SDK_DISABLED=true
OTEL_SERVICE_NAME=fastify-boilerplate
