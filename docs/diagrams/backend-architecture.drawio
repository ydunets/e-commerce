        <mxCell id="p1note" parent="p1srv" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;fontSize=11;fontColor=#666666;" value="Awilix DI autoloads repositories, mappers, and handlers by filename convention; handlers self-register on the bus in init(). Handlers depend on repository ports (interfaces) only; all SQL lives in repository adapters as parameterized tagged templates." vertex="1">
          <mxGeometry height="80" width="790" x="40" y="600" as="geometry" />
        </mxCell>
