        </mxCell>
        <mxCell id="p1client" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" value="Browser / SSR route loader&#xa;(apps/client)" vertex="1">
          <mxGeometry height="70" width="200" x="60" y="60" as="geometry" />
        </mxCell>
        <mxCell id="p1proxy" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" value="express /api proxy&#xa;(SSR server)" vertex="1">
          <mxGeometry height="70" width="200" x="60" y="210" as="geometry" />
        </mxCell>
        <mxCell id="p1srv" parent="1" style="swimlane;startSize=30;fontStyle=1;fontSize=13;fillColor=none;strokeColor=#6c8ebf;pointerEvents=0;" value="apps/server (Fastify 5, Clean Architecture + CQRS)" vertex="1">
          <mxGeometry height="700" width="860" x="520" y="120" as="geometry" />
        </mxCell>
